# Whatsim Configuration
# Copy this file to .env and adjust values as needed.

# Server bind address
WHATSIM_HOST=127.0.0.1
WHATSIM_PORT=3210

# Log level (trace, debug, info, warn, error)
WHATSIM_LOG_LEVEL=info

# Target webhook URL — Whatsim will POST Meta-style webhook payloads here
# when inbound messages are simulated. Point this at your app's webhook handler.
WHATSIM_WEBHOOK_TARGET=http://localhost:3000/api/webhooks/whatsapp

# SQLite persistence (disabled by default — runs fully in-memory)
WHATSIM_ENABLE_PERSISTENCE=false
WHATSIM_DB_PATH=

# Default organization ID for new conversations (optional)
WHATSIM_DEFAULT_ORGANIZATION_ID=

# Public base URL (used for generating mock callback URLs, etc.)
WHATSIM_PUBLIC_BASE_URL=http://127.0.0.1:3210
